---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Repositorio INFOCAB | Portal Academico',
  description = 'Catálogo filtrable de proyectos INFOCAB alojados en el Portal Academico del CCH.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-(--paper) text-(--ink) antialiased">
    <Header />
    <slot />
    <Footer />
  </body>
</html>

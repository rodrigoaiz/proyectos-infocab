---
import EmptyState from '../components/EmptyState.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SearchFilters from '../components/SearchFilters.astro';
import Layout from '../layouts/Layout.astro';
import { filterProjects, getAreas, getCategories, getStats, projects } from '../lib/projects';

const query = Astro.url.searchParams.get('q') ?? '';
const area = Astro.url.searchParams.get('area') ?? '';
const category = Astro.url.searchParams.get('category') ?? '';

const visibleProjects = filterProjects(projects, { query, area, category });
const visibleProjectIds = new Set(visibleProjects.map((project) => project.id));
const areas = getAreas(projects);
const categories = getCategories(projects);
const stats = getStats(projects);
---

<Layout
  title="Repositorio INFOCAB | Catálogo filtrable"
  description="Explora proyectos INFOCAB del Portal Academico mediante busqueda, categorias y areas del conocimiento compartibles por URL."
>
  <main class="mx-auto flex w-full max-w-7xl flex-1 flex-col gap-6 px-4 py-5 sm:gap-8 sm:px-6 sm:py-8 lg:px-10 lg:py-10">
    <Hero total={stats.total} areas={stats.areas} categories={stats.categories} />

    <SearchFilters
      areas={areas}
      categories={categories}
      query={query}
      area={area}
      category={category}
      visibleCount={visibleProjects.length}
      totalCount={projects.length}
    />

    <section class="space-y-4 sm:space-y-5">
      <div class="flex flex-col gap-4 border-b border-(--line) pb-4 sm:gap-5">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-(--muted)">Catálogo</p>
          <h2 class="mt-2 font-serif text-3xl text-(--ink) sm:text-4xl">Recursos listos para consulta</h2>
        </div>

      </div>

      <EmptyState hidden={visibleProjects.length !== 0} />

      <div class="grid gap-5 md:grid-cols-2 2xl:grid-cols-3" data-project-grid>
        {projects.map((project) => {
          const isVisible = visibleProjectIds.has(project.id);

          return (
            <div hidden={!isVisible}>
              <ProjectCard project={project} />
            </div>
          );
        })}
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.querySelector('[data-filters]');
      const cards = Array.from(document.querySelectorAll('[data-project-grid] > div'))
        .map((wrapper) => wrapper.querySelector('[data-project-card]'))
        .filter((card) => card instanceof HTMLElement);
      const label = document.querySelector('[data-results-label]');
      const emptyState = document.querySelector('[data-empty-state]');
      const clearButton = document.querySelector('[data-clear-filters]');

      if (!(form instanceof HTMLFormElement) || !label || !emptyState) return;

      const normalize = (value) =>
        value
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();

      const updateUrl = (params) => {
        const nextUrl = new URL(window.location.href);
        Object.entries(params).forEach(([key, value]) => {
          if (value) nextUrl.searchParams.set(key, value);
          else nextUrl.searchParams.delete(key);
        });
        window.history.replaceState({}, '', nextUrl);
      };

      const render = () => {
        const formData = new FormData(form);
        const query = normalize(String(formData.get('q') || ''));
        const area = String(formData.get('area') || '');
        const category = String(formData.get('category') || '');

        let visible = 0;

        cards.forEach((card) => {
          const matchesArea = !area || card.dataset.area === area;
          const matchesCategory = !category || card.dataset.category === category;
          const haystack = normalize([
            card.dataset.title,
            card.dataset.description,
            card.dataset.area,
            card.dataset.category,
            card.dataset.tags?.replaceAll('|', ' '),
          ].join(' '));
          const matchesQuery = !query || haystack.includes(query);
          const matches = matchesArea && matchesCategory && matchesQuery;
          const wrapper = card.parentElement;

          wrapper?.toggleAttribute('hidden', !matches);
          if (matches) visible += 1;
        });

        label.textContent = `${visible} de ${cards.length} recursos visibles`;
        emptyState.toggleAttribute('hidden', visible !== 0);
        updateUrl({ q: String(formData.get('q') || ''), area, category });
      };

      form.addEventListener('input', render);
      form.addEventListener('change', render);
      form.addEventListener('reset', () => {
        window.requestAnimationFrame(render);
      });

      clearButton?.addEventListener('click', () => {
        window.requestAnimationFrame(() => {
          const searchField = form.elements.namedItem('q');
          if (searchField instanceof HTMLInputElement) searchField.focus();
        });
      });
    })();
  </script>
</Layout>

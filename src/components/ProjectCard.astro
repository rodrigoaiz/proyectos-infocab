---
import { getAreaTone, type Project } from '../lib/projects';
import ProjectModal from './ProjectModal.astro';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const tone = getAreaTone(project.area);
const hasFullDescription = Boolean(project.fullDescription);
---

<article
  class="group relative grid h-full gap-4 overflow-hidden border border-(--card-border) bg-[linear-gradient(180deg,var(--card-surface),color-mix(in_oklab,var(--surface)_88%,white_12%))] p-4 transition duration-200 hover:-translate-y-1 hover:border-(--card-accent) hover:shadow-[0_24px_60px_-36px_color-mix(in_oklab,var(--card-accent)_34%,black_66%)] sm:gap-5 sm:p-5"
  data-project-card
  data-title={project.title}
  data-description={project.description}
  data-area={project.area}
  data-category={project.category}
  data-tags={project.tags.join('|')}
  style={`--card-accent:${tone.accent};--card-surface:${tone.soft};--card-border:color-mix(in oklab, ${tone.accent} 24%, var(--line));`}
>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-(--card-accent) opacity-85"></div>
  <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-(--muted)">
    <span class="border border-(--card-border) bg-(--card-surface) px-2 py-1 text-(--ink)">{project.area}</span>
    <span class="border border-[color-mix(in_oklab,var(--card-accent)_18%,var(--line))] px-2 py-1">{project.category}</span>
  </div>

  <div class="space-y-3">
    <h2 class="font-serif text-[1.55rem] leading-tight text-(--ink) transition group-hover:text-(--card-accent) sm:text-2xl">
      {project.title}
    </h2>
    <p class="max-w-[60ch] text-sm leading-6 text-(--ink-soft) sm:leading-7">{project.description}</p>
  </div>

  <div class="mt-auto flex items-center justify-end border-t border-(--line) pt-4">
    {hasFullDescription && (
      <button
        class="inline-flex items-center gap-2 text-sm font-medium text-(--card-accent) underline decoration-[color-mix(in_oklab,var(--card-accent)_45%,transparent)] underline-offset-4 transition hover:text-(--ink) mr-4"
        data-open-modal={project.id}
        aria-label={`Ver descripción completa de ${project.title}`}
      >
        Ver más
        <span aria-hidden="true">+</span>
      </button>
    )}
    <a
      class="inline-flex items-center gap-2 text-sm font-medium text-(--card-accent) underline decoration-[color-mix(in_oklab,var(--card-accent)_45%,transparent)] underline-offset-4 transition hover:text-(--ink)"
      href={project.url}
      target="_blank"
      rel="noreferrer"
      aria-label={`Abrir ${project.title} en una nueva pestana`}
    >
      Ver recurso
      <span aria-hidden="true">-></span>
    </a>
  </div>
</article>

{hasFullDescription && <ProjectModal project={project} />}

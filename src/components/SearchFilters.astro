---
type Props = {
  collections: string[];
  categories: string[];
  query: string;
  collection: string;
  category: string;
  visibleCount: number;
  totalCount: number;
};

const { collections, categories, query, collection, category, visibleCount, totalCount } = Astro.props;
---

<section class="sticky top-4 z-10 border border-[color:var(--line-strong)] bg-[color:color-mix(in oklab, var(--surface) 92%, white 8%)] p-4 backdrop-blur sm:p-5">
  <form class="grid gap-4 xl:grid-cols-[minmax(0,1.2fr)_repeat(2,minmax(0,0.55fr))_auto_auto] xl:items-end" data-filters>
    <label class="grid gap-2">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--muted)]">Buscar</span>
      <input
        class="min-h-12 border border-[color:var(--line)] bg-[color:var(--paper)] px-4 text-base text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)] focus:ring-2 focus:ring-[color:color-mix(in oklab, var(--accent) 26%, white 74%)]"
        type="search"
        name="q"
        value={query}
        placeholder="Titulo, descripcion o palabra clave"
        autocomplete="off"
      />
    </label>

    <label class="grid gap-2">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--muted)]">Coleccion</span>
      <select
        class="min-h-12 border border-[color:var(--line)] bg-[color:var(--paper)] px-4 text-base text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)] focus:ring-2 focus:ring-[color:color-mix(in oklab, var(--accent) 26%, white 74%)]"
        name="collection"
      >
        <option value="">Todas</option>
        {collections.map((item) => (
          <option value={item} selected={item === collection}>{item}</option>
        ))}
      </select>
    </label>

    <label class="grid gap-2">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--muted)]">Categoria</span>
      <select
        class="min-h-12 border border-[color:var(--line)] bg-[color:var(--paper)] px-4 text-base text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)] focus:ring-2 focus:ring-[color:color-mix(in oklab, var(--accent) 26%, white 74%)]"
        name="category"
      >
        <option value="">Todas</option>
        {categories.map((item) => (
          <option value={item} selected={item === category}>{item}</option>
        ))}
      </select>
    </label>

    <button
      class="min-h-12 bg-[color:var(--accent-strong)] px-5 font-medium text-[color:var(--paper)] transition hover:bg-[color:var(--ink)] focus:outline-none focus:ring-2 focus:ring-[color:color-mix(in oklab, var(--accent) 38%, white 62%)]"
      type="submit"
    >
      Aplicar
    </button>

    <button
      class="min-h-12 border border-[color:var(--line-strong)] px-4 font-medium text-[color:var(--ink)] transition hover:border-[color:var(--accent-strong)] hover:text-[color:var(--accent-strong)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-2 focus:ring-[color:color-mix(in oklab, var(--accent) 26%, white 74%)]"
      type="reset"
      data-clear-filters
    >
      Limpiar filtros
    </button>
  </form>

  <div class="mt-4 flex flex-col gap-3 border-t border-[color:var(--line)] pt-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-[color:var(--muted)]" aria-live="polite" data-results-label>
      {visibleCount} de {totalCount} recursos visibles
    </p>
    <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-[color:var(--muted)]">
      <span class="border border-[color:var(--line)] px-2 py-1">Busqueda compartible por URL</span>
      <span class="border border-[color:var(--line)] px-2 py-1">Filtrado por coleccion y categoria</span>
    </div>
  </div>
</section>

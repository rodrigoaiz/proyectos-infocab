---
type Props = {
  collections: string[];
  categories: string[];
  query: string;
  collection: string;
  category: string;
  visibleCount: number;
  totalCount: number;
};

const { collections, categories, query, collection, category, visibleCount, totalCount } = Astro.props;
---

<details class="filters-panel relative overflow-hidden border border-[color-mix(in_oklab,var(--portal-plum)_35%,var(--line))] bg-[linear-gradient(135deg,color-mix(in_oklab,var(--portal-plum)_5%,white_95%),color-mix(in_oklab,var(--portal-teal)_4%,white_96%))] shadow-[0_20px_60px_-48px_color-mix(in_oklab,var(--portal-plum)_35%,black_65%)] backdrop-blur" data-filters-panel open>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-[linear-gradient(90deg,var(--portal-plum),var(--portal-orange),var(--portal-lime),var(--portal-teal))]"></div>

  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 marker:hidden sm:px-5 transition-colors hover:bg-white/40">
    <div class="flex items-center gap-3 sm:gap-4">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-(--accent-strong)">Filtros</p>
      <p class="text-sm text-(--muted)">{visibleCount} de {totalCount} recursos</p>
    </div>
    <span class="inline-flex items-center gap-2 text-sm font-medium text-(--ink)">
      <span class="hidden sm:inline">Buscar</span>
      <svg class="h-5 w-5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </span>
  </summary>

  <div class="filters-body p-4 pt-3 sm:p-5 sm:pt-4">
    <div class="mb-4 flex flex-col gap-3 border-b border-(--line) pb-4 md:flex-row md:items-start md:justify-between">
      <div class="space-y-1">
        <h2 class="text-xl text-(--ink) sm:text-2xl">Herramienta de búsqueda</h2>
        <p class="max-w-2xl text-sm leading-6 text-(--muted)">
          Escribe un tema, una asignatura o una palabra clave. Los resultados se actualizan mientras exploras.
        </p>
      </div>
    </div>

    <form class="grid gap-4 sm:gap-5 md:grid-cols-2 xl:grid-cols-[1.2fr_1fr_1fr_auto] xl:gap-6 xl:items-end" data-filters>
      <label class="grid gap-2 md:col-span-2 xl:col-span-1">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-(--muted)">Buscar</span>
        <input
          class="min-h-12 border border-[color-mix(in_oklab,var(--portal-plum)_25%,var(--line))] bg-[color-mix(in_oklab,var(--portal-plum)_3%,white_97%)] px-4 text-base text-(--ink) outline-none transition focus:border-(--portal-plum) focus:ring-2 focus:ring-[color-mix(in_oklab,var(--portal-plum)_22%,white_78%)]"
          type="search"
          name="q"
          value={query}
          placeholder="Ej. biologia, trigonometria, ingles 3"
          autocomplete="off"
        />
      </label>

      <label class="grid gap-2">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-(--muted)">Coleccion</span>
        <select
          class="min-h-12 border border-[color-mix(in_oklab,var(--portal-orange)_26%,var(--line))] bg-[color-mix(in_oklab,var(--portal-orange)_4%,white_96%)] px-4 text-base text-(--ink) outline-none transition focus:border-(--portal-orange) focus:ring-2 focus:ring-[color-mix(in_oklab,var(--portal-orange)_24%,white_76%)]"
          name="collection"
        >
          <option value="">Todas</option>
          {collections.map((item) => (
            <option value={item} selected={item === collection}>{item}</option>
          ))}
        </select>
      </label>

      <label class="grid gap-2">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-(--muted)">Categoria</span>
        <select
          class="min-h-12 border border-[color-mix(in_oklab,var(--portal-teal)_28%,var(--line))] bg-[color-mix(in_oklab,var(--portal-teal)_4%,white_96%)] px-4 text-base text-(--ink) outline-none transition focus:border-(--portal-teal) focus:ring-2 focus:ring-[color-mix(in_oklab,var(--portal-teal)_22%,white_78%)]"
          name="category"
        >
          <option value="">Todas</option>
          {categories.map((item) => (
            <option value={item} selected={item === category}>{item}</option>
          ))}
        </select>
      </label>

      <button
        class="min-h-12 min-w-35 border border-[color-mix(in_oklab,var(--portal-lime)_40%,var(--line-strong))] bg-[color-mix(in_oklab,var(--portal-lime)_6%,white_94%)] px-5 font-medium text-(--ink) transition hover:border-(--portal-lime) hover:text-(--portal-plum) focus:border-(--portal-lime) focus:outline-none focus:ring-2 focus:ring-[color-mix(in_oklab,var(--portal-lime)_24%,white_76%)] md:col-span-2 xl:col-span-1 xl:w-auto xl:self-end"
        type="reset"
        data-clear-filters
      >
        Borrar filtros
      </button>
    </form>
  </div>
</details>

<script is:inline>
  (() => {
    const panel = document.querySelector('[data-filters-panel]');
    if (!(panel instanceof HTMLDetailsElement)) return;

    // Animar el chevron cuando se abre/cierra
    const summary = panel.querySelector('summary');
    const chevron = summary?.querySelector('svg');
    
    panel.addEventListener('toggle', () => {
      if (chevron) {
        chevron.style.transform = panel.open ? 'rotate(180deg)' : 'rotate(0deg)';
      }
    });

    // Auto-cerrar después de aplicar filtros (cuando cambian los inputs)
    const form = panel.querySelector('[data-filters]');
    if (form) {
      const inputs = form.querySelectorAll('input, select');
      
      inputs.forEach(input => {
        input.addEventListener('change', () => {
          // Esperar un poco antes de cerrar para que se vea el cambio
          setTimeout(() => {
            if (window.innerWidth >= 1024) {
              panel.open = false;
            }
          }, 300);
        });
      });
    }
  })();
</script>

<style>
  details[data-filters-panel][open] summary svg {
    transform: rotate(180deg);
  }
</style>

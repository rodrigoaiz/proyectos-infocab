---
import type { Project } from '../data/projects';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const hasEnrichedData = !!(project.fullDescription || project.authors || project.year || project.subject);
---

{hasEnrichedData && (
  <div 
    class="project-modal fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4"
    data-modal={project.id}
    aria-hidden="true"
    role="dialog"
    aria-labelledby={`modal-title-${project.id}`}
  >
    <div class="modal-content relative w-full max-w-3xl max-h-[90vh] overflow-hidden border border-[color-mix(in_oklab,var(--portal-plum)_35%,var(--line))] bg-[linear-gradient(135deg,color-mix(in_oklab,var(--portal-plum)_5%,white_95%),color-mix(in_oklab,var(--portal-teal)_4%,white_96%))] shadow-2xl">
      <!-- Header -->
      <div class="sticky top-0 z-10 border-b border-(--line) bg-white/80 backdrop-blur-sm px-6 py-4">
        <div class="flex items-start justify-between gap-4">
          <h2 id={`modal-title-${project.id}`} class="flex-1 font-serif text-2xl text-(--ink) leading-tight">
            {project.title}
          </h2>
          <button
            class="modal-close flex-shrink-0 flex items-center justify-center w-8 h-8 rounded-full border border-(--line) bg-(--paper) text-(--ink) transition hover:border-(--portal-plum) hover:bg-(--portal-plum-soft) focus:outline-none focus:ring-2 focus:ring-(--portal-plum)"
            aria-label="Cerrar"
            data-close-modal={project.id}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        
        <!-- Metadata badges -->
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          <span class="inline-flex items-center rounded-full border border-[color-mix(in_oklab,var(--portal-orange)_30%,var(--line))] bg-[color-mix(in_oklab,var(--portal-orange)_8%,white_92%)] px-3 py-1 font-medium text-(--ink)">
            {project.area}
          </span>
          <span class="inline-flex items-center rounded-full border border-[color-mix(in_oklab,var(--portal-teal)_30%,var(--line))] bg-[color-mix(in_oklab,var(--portal-teal)_8%,white_92%)] px-3 py-1 font-medium text-(--ink)">
            {project.category}
          </span>
          {project.subject && (
            <span class="inline-flex items-center rounded-full border border-[color-mix(in_oklab,var(--portal-lime)_30%,var(--line))] bg-[color-mix(in_oklab,var(--portal-lime)_8%,white_92%)] px-3 py-1 font-medium text-(--ink)">
              {project.subject}
            </span>
          )}
          {project.format && (
            <span class="inline-flex items-center rounded-full border border-[color-mix(in_oklab,var(--portal-plum)_30%,var(--line))] bg-[color-mix(in_oklab,var(--portal-plum)_8%,white_92%)] px-3 py-1 font-medium text-(--ink)">
              {project.format}
            </span>
          )}
        </div>
      </div>

      <!-- Content -->
      <div class="overflow-y-auto max-h-[calc(90vh-200px)] px-6 py-5">
        {project.fullDescription && (
          <div class="mb-6">
            <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-(--muted) mb-3">Descripción</h3>
            <div class="prose prose-sm max-w-none text-(--ink) leading-relaxed whitespace-pre-line">
              {project.fullDescription}
            </div>
          </div>
        )}

        {project.authors && (
          <div class="mb-6">
            <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-(--muted) mb-2">Autores</h3>
            <p class="text-(--ink) leading-relaxed">{project.authors}</p>
          </div>
        )}

        {project.year && (
          <div class="mb-6">
            <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-(--muted) mb-2">Año de publicación</h3>
            <p class="text-(--ink)">{project.year}</p>
          </div>
        )}
      </div>

      <!-- Footer -->
      <div class="sticky bottom-0 border-t border-(--line) bg-white/80 backdrop-blur-sm px-6 py-4">
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded border border-(--portal-plum) bg-(--portal-plum) px-5 py-2.5 text-sm font-medium text-white transition hover:bg-(--accent-strong) focus:outline-none focus:ring-2 focus:ring-(--portal-plum) focus:ring-offset-2"
        >
          Ver recurso en Portal Académico
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
)}

<script>
  // Handle modal open/close
  document.addEventListener('DOMContentLoaded', () => {
    // Open modal handlers
    document.querySelectorAll('[data-open-modal]').forEach(button => {
      button.addEventListener('click', () => {
        const modalId = button.getAttribute('data-open-modal');
        const modal = document.querySelector(`[data-modal="${modalId}"]`);
        if (modal) {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Close modal handlers
    document.querySelectorAll('[data-close-modal]').forEach(button => {
      button.addEventListener('click', () => {
        const modalId = button.getAttribute('data-close-modal');
        const modal = document.querySelector(`[data-modal="${modalId}"]`);
        if (modal) {
          modal.classList.remove('flex');
          modal.classList.add('hidden');
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
      });
    });

    // Close on backdrop click
    document.querySelectorAll('.project-modal').forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          const modalId = modal.getAttribute('data-modal');
          const closeButton = modal.querySelector(`[data-close-modal="${modalId}"]`);
          if (closeButton) {
            closeButton.click();
          }
        }
      });
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const openModal = document.querySelector('.project-modal.flex');
        if (openModal) {
          const modalId = openModal.getAttribute('data-modal');
          const closeButton = openModal.querySelector(`[data-close-modal="${modalId}"]`);
          if (closeButton) {
            closeButton.click();
          }
        }
      }
    });
  });
</script>

      <a target="_blank" href="https://www.unam.mx/" aria-label="Universidad Nacional Autónoma de México">
        <img src="/logo-unam.svg" alt="UNAM" class="hidden h-8 w-auto brightness-0 invert md:block lg:h-12" />
